# --- REQUIRED ---

# MongoDB — runs in compose (service name "mongo"). Leave the default unless
# you want to point at an external Mongo (Atlas, etc.).
MONGO_URL=mongodb://mongo:27017
DB_NAME=panorama_comms

# JWT signing key — generate with: openssl rand -hex 32
JWT_SECRET=5df7d846afca632cf04243568a9366adc9e61453a8275e979de0b6c36ba48c30

# Admin seeded on first boot
ADMIN_EMAIL=operations@panoramacoaches.com.au
ADMIN_PASSWORD=Pano3666
ADMIN_NAME=Operations Admin

# --- HTTPS / domain ---

# === Option A: Real domain (RECOMMENDED — free Let's Encrypt cert) ===
# Make sure your DNS A record points the domain at this VM's public IP and
# OCI Security List + the VM firewall allow TCP 80 (Let's Encrypt challenge)
# AND TCP 443.
#
 CADDY_HOST=panoramachat.fitzell.au
 ACME_EMAIL=aaron.fitzell@fitzell.au
 FRONTEND_URL=https://panoramachat.fitzell.au

# === Option B: IP-only / self-signed (browser warning once) ===
# Uncomment the `tls internal` line in Caddyfile, then:
#
# CADDY_HOST=:443
# ACME_EMAIL=admin@example.com
# FRONTEND_URL=

CADDY_HOST=panoramachat.fitzell.au
ACME_EMAIL=aaron.fitzell@fitzell.au
FRONTEND_URL=https://panoramachat.fitzell.au
CORS_ORIGINS=*

# Cookie defaults — DO NOT change unless you know what you're doing.
COOKIE_SAMESITE=lax
COOKIE_SECURE=true

# --- INTEGRATIONS (optional) ---
GIPHY_API_KEY=rbDJoM1l6mT7cRRw9nlkvPHq4VSuM6tO

